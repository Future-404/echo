# Echo Storage 后端配置示例
# 复制此文件为 .env 并填入实际值

# 认证 Token（必需）- 生成强随机字符串，至少 32 字符
# 生成方法: openssl rand -hex 32
AUTH_TOKEN=your_secret_token_here_min_32_chars

# 允许的前端域名（必需）- 生产环境必须设置具体域名
# 开发: http://localhost:8888
# 生产: https://your-domain.com
ALLOWED_ORIGIN=*

# 数据库路径（可选）
DB_PATH=./echo.db

# 服务端口（可选）
PORT=3456
