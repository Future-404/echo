# Echo 部署配置

# ── Docker / Node 部署 ──────────────────────────────────────────────────────
# 后端认证 Token（必须修改！）
# 生成方法: openssl rand -hex 32
AUTH_TOKEN=please_change_this_token

# ── 纯前端部署（无后端，托管到 GitHub Pages / Vercel 等）────────────────────
# 构建时注入的访问密码，GateScreen 直接本地比对，不依赖后端
# 留空则 GateScreen 接受任意密码（开发/演示模式）
VITE_AUTH_TOKEN=

# 后端 API 地址（有后端时填写，留空则纯本地 IndexedDB 存储）
VITE_API_URL=
